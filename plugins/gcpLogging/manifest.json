{
  "name": "gcpLogging",
  "description": "GCP Cloud Logging MCP — query logs from multiple GCP environments",
  "prerequisites": [],
  "container": {
    "mounts": [
      {
        "hostPath": "~/.config/nanoclaw/nanoclaw-logs-reader-sa-prod.json",
        "containerPath": "/secrets/gcp-sa-prod.json",
        "readonly": true
      },
      {
        "hostPath": "~/.config/nanoclaw/nanoclaw-logs-reader-sa-demo.json",
        "containerPath": "/secrets/gcp-sa-demo.json",
        "readonly": true
      }
    ],
    "envVars": {},
    "entrypointCommands": [],
    "mcpServers": {
      "gcp_logging": {
        "scriptPath": "gcp-logging-mcp.js",
        "env": {
          "GCP_ENVIRONMENTS": "{\"prod\":\"/secrets/gcp-sa-prod.json\",\"demo\":\"/secrets/gcp-sa-demo.json\"}"
        }
      }
    },
    "allowedTools": ["mcp__gcp_logging__*"],
    "skills": []
  },
  "setupInstructions": "Place GCP service account JSON files (Logs Viewer role) at the host paths declared in mounts. Edit GCP_ENVIRONMENTS to set environment names. The container-runner skips any SA files that don't exist on the host."
}
