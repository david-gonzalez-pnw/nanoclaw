# Required: Claude Code OAuth token for the credential proxy
CLAUDE_CODE_OAUTH_TOKEN=

# Optional: Bot display name (default: Andy)
# ASSISTANT_NAME=Andy

# Slack channel (required if using Slack)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Product Input Facilitator (optional)
# Watches a configured GitHub repo for PRs labeled `product-input-required`,
# runs a Slack questionnaire wizard, writes the decision table back to the PR.
# Auth comes from the `gh` CLI (`gh auth token`) — make sure `gh auth status`
# shows a logged-in account with `repo` scope on the watched repo.
# PI_ENABLED=false
# PI_GITHUB_REPO=<owner>/<repo>
# PI_SLACK_CHANNEL=<slack-channel-id>          # channel ID, not name
# PI_LABEL_REQUIRED=product-input-required
# PI_LABEL_PENDING=product-input-pending
# PI_LABEL_RESOLVED=product-input-resolved
# PI_RFC_DIR=docs/rfcs
# PI_FEATURE_NAME="Product Input"              # used in user-facing copy
# PI_TEAM_FILE=~/.config/nanoclaw/pi-team.json # see docs/plans/pi-resolution-slack-confirmation.md for shape
#
# Phase 2 — lock resolved decisions back into RFC files via the
# `commit-pi-decisions` container skill. Off by default; when on, every
# resolved PR gets a follow-up commit on its branch with the per-PI
# **Final decision:** blocks. Requires PI_FINALIZE_GROUP to point at a
# registered group that mounts the watched repo writable.
# PI_COMMIT_DECISIONS=false
# PI_FINALIZE_GROUP=<group-folder-name>        # e.g. slack_<channel-name>

# Google Chat channel (MCP server URL — set to enable GChat inbound)
# GCHAT_MCP_URL=http://localhost:3900/sse

# Optional: Custom alias in container names: nanoclaw-{alias}-{group}-{ts}
# CONTAINER_ALIAS=<short-alias>

# Optional: Credential proxy port (default: 3001)
# CREDENTIAL_PROXY_PORT=3001

# Optional: Ollama for channel-agnostic message formatting
# OLLAMA_URL=http://localhost:11434
# OLLAMA_FORMATTER_MODEL=qwen3.5

# Transcription sidecar (faster-whisper). Off by default; flip to true to
# spawn the Python sidecar for voice transcription. Requires
# `transcription-service/setup.sh` to have been run once (creates .venv).
TRANSCRIPTION_ENABLED=false
# TRANSCRIPTION_PORT=3003
# Model accuracy ranking: large-v3 > medium > large-v3-turbo > small > base > tiny.
# large-v3 is slower than turbo but noticeably more accurate on short words,
# names, and soft speech. Turbo is the fastest "good" model; use it on CPU.
# TRANSCRIPTION_MODEL=large-v3
# TRANSCRIPTION_DEVICE=cuda            # or cpu
